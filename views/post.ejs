<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> — the board</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="brand">
      <%- include('partials/brand') %>
    </div>
  </header>
  <article class="post-single">
    <h1><%= post.title %></h1>
    <div class="post-meta"><%= post.username %> · <%= vagueDate(post.created_at) %> · <span class="views"><%= typeof post.views !== 'undefined' ? post.views : (post.likes || 0) %></span></div>
    <div class="body"><%= post.body %></div>
    <p class="post-share" data-post-url="<%= postUrl %>">share <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(postUrl) %>&text=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener">on X</a> · <button type="button" class="link-btn copy-link-btn">copy link</button></p>
  </article>
  <p><a href="/">&larr; back</a></p>

  <section class="comments-section">
    <h2><span class="prompt">/> </span>comments</h2>
    <p><button type="button" class="link-btn open-comment-modal">leave a comment</button></p>
    <% if (typeof comments !== 'undefined' && comments.length) { %>
    <ul class="comment-list">
      <% comments.forEach(function(c) { %>
      <li class="comment">
        <div class="comment-meta"><%= c.username %> · <%= vagueDate(c.created_at) %></div>
        <div class="comment-body"><%= c.body %></div>
      </li>
      <% }); %>
    </ul>
    <% } else { %>
    <p class="no-comments">no comments yet.</p>
    <% } %>
  </section>

  <div id="comment-modal" class="modal" aria-hidden="true">
    <div class="modal-overlay"></div>
    <div class="modal-box">
      <h2><span class="prompt">/> </span>leave a comment</h2>
      <form action="/post/<%= post.id %>/comment" method="post">
        <label>username</label>
        <input type="text" name="username" placeholder="anon" autocomplete="off">
        <label>comment</label>
        <textarea name="body" required placeholder="your comment..."></textarea>
        <button type="submit">send</button>
      </form>
      <button type="button" class="link-btn close-comment-modal">cancel</button>
    </div>
  </div>
  <script>
    (function() {
      var modal = document.getElementById('comment-modal');
      function openModal() { modal.classList.add('open'); modal.setAttribute('aria-hidden', 'false'); }
      function closeModal() { modal.classList.remove('open'); modal.setAttribute('aria-hidden', 'true'); }
      document.querySelector('.open-comment-modal').onclick = openModal;
      document.querySelector('.close-comment-modal').onclick = closeModal;
      document.querySelector('#comment-modal .modal-overlay').onclick = closeModal;
      if (window.location.search.indexOf('err=comment') !== -1) openModal();
      var copyBtn = document.querySelector('.copy-link-btn');
      var shareEl = document.querySelector('.post-share');
      if (copyBtn && shareEl) {
        copyBtn.onclick = function() {
          var url = shareEl.getAttribute('data-post-url');
          if (url) navigator.clipboard.writeText(url).then(function() {
            copyBtn.textContent = 'copied';
            setTimeout(function() { copyBtn.textContent = 'copy link'; }, 1500);
          });
        };
      }
    })();
  </script>
</body>
</html>
