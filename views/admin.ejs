<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>admin — the board</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="brand">
      <%- include('partials/brand') %>
    </div>
  </header>
  <h1><span class="prompt">/> </span>admin</h1>
  <p><a href="/">home</a> · <form action="/admin/logout" method="get" style="display:inline"><button type="submit" class="link-btn">logout</button></form></p>
  <h2>posts</h2>
  <ul class="post-list admin-list">
    <% posts.forEach(function(p) { %>
    <li>
      <% if (p.pinned) { %><span class="pinned-badge">pinned</span> <% } %>
      <a href="/post/<%= p.id %>"><%= p.title %></a>
      <span class="post-meta">· <%= p.username %> · <%= vagueDate(p.created_at) %> · <%= p.likes || 0 %> views</span>
      <% if (p.pinned) { %>
      <form action="/admin/unpin" method="post" style="display:inline; margin-left: 0.25rem;">
        <button type="submit" class="link-btn admin-pin">[unpin]</button>
      </form>
      <% } else { %>
      <form action="/admin/pin/<%= p.id %>" method="post" style="display:inline; margin-left: 0.25rem;">
        <button type="submit" class="link-btn admin-pin">[pin]</button>
      </form>
      <% } %>
      <form action="/admin/delete/<%= p.id %>" method="post" style="display:inline; margin-left: 0.25rem;">
        <button type="submit" class="like-btn del">[delete]</button>
      </form>
    </li>
    <% }); %>
  </ul>
  <% if (posts.length === 0) { %><p>no posts.</p><% } %>

  <section class="admin-chat-section">
    <h2><span class="prompt">/> </span>chatboard</h2>
    <% if (typeof chatMessages !== 'undefined' && chatMessages.length) { %>
    <ul class="admin-chat-list post-list">
      <% chatMessages.forEach(function(m) { %>
      <li>
        <span class="chat-msg-preview"><strong><%= m.username %></strong> · <%= m.body.substring(0, 60) %><%= m.body.length > 60 ? '…' : '' %> · <%= vagueDate(m.created_at) %></span>
        <form action="/admin/chat/delete/<%= m.id %>" method="post" style="display:inline;">
          <button type="submit" class="like-btn del">[delete]</button>
        </form>
      </li>
      <% }); %>
    </ul>
    <% } else { %>
    <p class="no-comments">no messages.</p>
    <% } %>
  </section>
</body>
</html>
